#!/bin/sh
set -e

REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT"

echo "==> running buildx CI checks and runtime image cache"
./fido ci

# Enforce fresh model mirrors.  When any models/*.v file is staged, the
# working-tree copy of src/fido/rocq/ must match the index — a
# diff here means generated Python changed but was not staged.
if git diff --cached --name-only | grep -q '^models/.*\.v$'; then
  echo "==> checking model mirrors (models/*.v staged)"
  if ! git diff --quiet -- src/fido/rocq/; then
    echo ""
    echo "Error: src/fido/rocq/ has unstaged changes while models/*.v"
    echo "is staged for commit.  Generated Python changed but was not"
    echo "staged.  Fix with:"
    echo ""
    echo "  git add src/fido/rocq/"
    echo ""
    echo "then retry the commit."
    exit 1
  fi
fi
