#!/usr/bin/env bash
set -euo pipefail

repo_root=$(git rev-parse --show-toplevel 2>/dev/null || pwd)
image=${FIDO_IMAGE:-fido:local}
test_image=${FIDO_TEST_IMAGE:-fido-test:local}
rocq_repl_image=${FIDO_ROCQ_REPL_IMAGE:-fido-rocq-repl:local}
run_image=$image
container=${FIDO_CONTAINER:-fido}
secret=${FIDO_SECRET:-$HOME/.fido-secret}
fido_log=${FIDO_LOG:-$HOME/log/fido.log}
auto_update=${FIDO_AUTO_UPDATE:-1}
prune_on_restart=${FIDO_PRUNE_ON_RESTART:-1}
prune_keep_storage=${FIDO_BUILDKIT_KEEP_STORAGE:-24gb}
builder=${FIDO_BUILDX_BUILDER:-fido}
build_graph=$repo_root/tools/build_graph.sh
need_secret=0
named_run=0
quiet=0
container_entrypoint=
restart_codes=" 3 75 "
stop_codes=" 0 130 137 143 "

if [ -f "$build_graph" ]; then
  # Generated by ./fido gen-workflows. Provides fido_build_targets_for_group
  # and fido_build_inputs_for_target.
  # shellcheck source=/dev/null
  source "$build_graph"
fi

args=()
while [ "$#" -gt 0 ]; do
  case "$1" in
    --no-auto-update)
      auto_update=0
      ;;
    --auto-update)
      auto_update=1
      ;;
    *)
      args+=("$1")
      ;;
  esac
  shift
done
set -- "${args[@]}"
command=${1:-help}

log() {
  if [ "$quiet" = "1" ]; then
    return
  fi
  printf '%(%H:%M:%S)T %-5s [supervisor] %s\n' -1 "$1" "$2" >&2
}

redirect_up_logs() {
  mkdir -p "$(dirname "$fido_log")"
  log INFO "redirecting up output to $fido_log"
  exec >>"$fido_log" 2>&1
  log INFO "up log opened"
}

buildx_driver() {
  local inspect_output
  if ! inspect_output=$(docker buildx inspect 2>&1); then
    echo "warning: docker buildx inspect failed; assuming docker driver" >&2
    echo "$inspect_output" >&2
    printf 'docker\n'
    return
  fi
  awk -F': *' '/^Driver:/{print $2; exit}' <<<"$inspect_output"
}

ensure_buildx_builder() {
  local driver
  driver=$(buildx_driver)
  if [ "$driver" != "docker" ]; then
    return
  fi

  log INFO "switching buildx to docker-container builder=$builder"
  if docker buildx inspect "$builder" >/dev/null 2>&1; then
    docker buildx use "$builder" >/dev/null
  else
    docker buildx create --name "$builder" --driver docker-container --use >/dev/null
  fi
  docker buildx inspect --bootstrap >/dev/null
}

image_cache_ready() {
  local tag=$2
  docker image inspect "$tag" >/dev/null 2>&1
}

ci_cache_ready() {
  return 0
}

require_build_graph() {
  if ! declare -F fido_build_targets_for_group >/dev/null \
    || ! declare -F fido_build_inputs_for_target >/dev/null; then
    echo "build graph missing; run ./fido gen-workflows" >&2
    return 2
  fi
}

target_input_files() {
  local target=$1
  local path
  require_build_graph
  (
    cd "$repo_root"
    while IFS= read -r path; do
      [ -n "$path" ] || continue
      if [[ "$path" == *"*"* || "$path" == *"?"* || "$path" == *"["* ]]; then
        compgen -G "$path" || true
      elif [ -d "$path" ]; then
        find "$path" -type f -print
      elif [ -f "$path" ]; then
        printf '%s\n' "$path"
      fi
    done < <(fido_build_inputs_for_target "$target")
  ) | LC_ALL=C sort -u
}

target_input_hash() {
  local target=$1
  local files=()
  mapfile -t files < <(target_input_files "$target")
  (
    cd "$repo_root"
    {
      if [ "${#files[@]}" -gt 0 ]; then
        sha256sum "${files[@]}"
      else
        printf 'empty\n'
      fi
      printf 'target %s\n' "$target"
      printf 'uid %s\n' "$(id -u)"
      printf 'gid %s\n' "$(id -g)"
      printf 'user %s\n' "$(id -un)"
      printf 'home %s\n' "$HOME"
    } | sha256sum | awk '{print $1}'
  )
}

run_with_bake_env() {
  FIDO_IMAGE="$image" \
    FIDO_TEST_IMAGE="$test_image" \
    FIDO_ROCQ_REPL_IMAGE="$rocq_repl_image" \
    FIDO_UID="$(id -u)" \
    FIDO_GID="$(id -g)" \
    FIDO_USER="$(id -un)" \
    FIDO_HOME="$HOME" \
    "$@"
}

make_rocq_usage() {
  cat >&2 <<'EOF'
usage:
  ./fido make-rocq [docker buildx bake args...]
  ./fido make-rocq --smart-output DIR [--manifest-cache FILE] -- <command> [args...]

With no mode flag, builds Rocq models through buildx and writes generated
Python to src/fido/rocq/.

With --smart-output, runs the command and removes stale files from DIR after
the command produces a fresh output manifest or fresh files.
EOF
}

hash_paths() {
  local existing=()
  local path
  for path in "$@"; do
    if [ -f "$path" ]; then
      existing+=("$path")
    fi
  done
  if [ "${#existing[@]}" -eq 0 ]; then
    printf 'empty\n'
    return
  fi
  sha256sum "${existing[@]}" | LC_ALL=C sort -k 2 | sha256sum | awk '{print $1}'
}

make_rocq_input_hash() {
  local paths=()
  mapfile -t paths < <(target_input_files make-rocq)
  (
    cd "$repo_root"
    hash_paths "${paths[@]}"
  )
}

make_rocq_generated_hash() {
  local paths=()
  mapfile -t paths < <(
    find "$repo_root/src/fido/rocq" \
      -type f \
      ! -name ".build-files" \
      ! -name "*.pyc" \
      ! -path "*/__pycache__/*" \
      -print \
      | LC_ALL=C sort
  )
  hash_paths "${paths[@]}"
}

make_rocq_fingerprint() {
  printf 'inputs %s\n' "$(make_rocq_input_hash)"
  printf 'generated %s\n' "$(make_rocq_generated_hash)"
}

prune_smart_output_manifest() {
  local smart_output=$1
  local manifest=$2

  if [ ! -s "$manifest" ]; then
    echo "smart output manifest is empty: $manifest" >&2
    return 1
  fi

  while IFS= read -r -d '' file; do
    local rel=${file#"$smart_output"/}
    if [ "$rel" = ".build-files" ]; then
      continue
    fi
    if ! grep -Fxq "$rel" "$manifest"; then
      rm -f "$file"
    fi
  done < <(find "$smart_output" -type f -print0)

  find "$smart_output" -depth -type d -empty -delete
}

make_rocq_smart_output() {
  local smart_output=
  local manifest_cache=

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --smart-output)
        if [ "$#" -lt 2 ]; then
          make_rocq_usage
          return 2
        fi
        smart_output=$2
        shift 2
        ;;
      --manifest-cache)
        if [ "$#" -lt 2 ]; then
          make_rocq_usage
          return 2
        fi
        manifest_cache=$2
        shift 2
        ;;
      --)
        shift
        break
        ;;
      *)
        make_rocq_usage
        return 2
        ;;
    esac
  done

  if [ -z "$smart_output" ] || [ "$#" -eq 0 ]; then
    make_rocq_usage
    return 2
  fi

  local marker
  marker=$(mktemp)
  trap 'rm -f "$marker"' RETURN

  "$@"

  if [ ! -d "$smart_output" ]; then
    echo "smart output directory was not produced: $smart_output" >&2
    return 1
  fi

  local manifest="$smart_output/.build-files"
  if [ -f "$manifest" ]; then
    if [ -n "$manifest_cache" ]; then
      mkdir -p "$(dirname "$manifest_cache")"
      cp "$manifest" "$manifest_cache"
    fi

    prune_smart_output_manifest "$smart_output" "$manifest"
    rm -f "$manifest"
    return 0
  fi

  if ! find "$smart_output" -type f -cnewer "$marker" -print -quit | grep -q .; then
    echo "smart output directory has no newly produced files: $smart_output" >&2
    return 1
  fi

  find "$smart_output" -type f ! -cnewer "$marker" -delete
  rm -f "$manifest"
  find "$smart_output" -depth -type d -empty -delete

  if [ -n "$manifest_cache" ]; then
    mkdir -p "$(dirname "$manifest_cache")"
    (
      cd "$smart_output"
      find . -type f -printf "%P\n" | LC_ALL=C sort > "$manifest_cache"
    )
  fi
}

make_rocq_models() {
  local cache_context="$repo_root/.cache/rocq-models/context"
  local manifest="$repo_root/.cache/rocq-models/manifest.sha"
  local generated_manifest="$repo_root/.cache/rocq-models/generated-files"
  local build_args=("$@")
  mkdir -p "$cache_context/_build"
  ensure_buildx_builder

  local current
  current=$(make_rocq_fingerprint)
  if [ "${#build_args[@]}" -eq 0 ] \
    && [ -f "$manifest" ] \
    && [ "$(cat "$manifest")" = "$current" ]; then
    echo "models build cache hit" >&2
    if [ -f "$generated_manifest" ]; then
      prune_smart_output_manifest "$repo_root/src/fido/rocq" "$generated_manifest"
    fi
    return
  fi

  (
    cd "$repo_root"
    "$repo_root/fido" make-rocq \
      --smart-output "$repo_root/src/fido/rocq" \
      --manifest-cache "$generated_manifest" \
      -- \
      docker buildx bake \
        "${build_args[@]}" \
        make-rocq
  )

  if [ -f "$generated_manifest" ]; then
    prune_smart_output_manifest "$repo_root/src/fido/rocq" "$generated_manifest"
  fi
  make_rocq_fingerprint > "$manifest"
}

sync_runner() {
  if [ "$auto_update" = "0" ]; then
    log INFO "auto-update disabled; using dirty runner clone as-is"
    return
  fi

  log INFO "cleaning runner clone before sync"
  git -C "$repo_root" reset --hard
  git -C "$repo_root" clean -fd -e .cache/
  log INFO "syncing runner clone from origin/main"
  git -C "$repo_root" fetch origin main
  git -C "$repo_root" reset --hard origin/main
}

build_image() {
  local target=$1
  local tag=$2
  local build_output=
  ensure_buildx_builder
  local manifest="$repo_root/.cache/rocq-models/$target.sha"
  local current
  current=$(target_input_hash "$target")
  mkdir -p "$repo_root/.cache/rocq-models"

  if [ -f "$manifest" ] \
    && [ "$(cat "$manifest")" = "$current" ] \
    && image_cache_ready "$target" "$tag"; then
    log INFO "$target image cache hit $tag"
    run_image=$tag
    return
  fi

  log INFO "building $target image $tag"
  if [ "$quiet" = "1" ]; then
    build_output=$(mktemp)
    if ! (
      cd "$repo_root"
      run_with_bake_env docker buildx bake "$target"
    ) >"$build_output" 2>&1; then
      cat "$build_output" >&2
      rm -f "$build_output"
      return 1
    fi
    rm -f "$build_output"
  else
    (
      cd "$repo_root"
      run_with_bake_env docker buildx bake "$target"
    )
  fi

  printf '%s\n' "$current" > "$manifest"
  run_image=$tag
}

ci_images() {
  local passthrough=("$@")
  ensure_buildx_builder
  local bake_args=()
  local target
  local target_hashes=()
  local line
  local digest
  local manifest
  local ci_hit=1
  mkdir -p "$repo_root/.cache/rocq-models/context/_build"
  mkdir -p "$repo_root/.cache/rocq-models/ci"
  while IFS= read -r target; do
    target_hashes+=("$target $(target_input_hash "$target")")
  done < <(fido_build_targets_for_group ci)

  for line in "${target_hashes[@]}"; do
    target=${line%% *}
    digest=${line#* }
    manifest="$repo_root/.cache/rocq-models/ci/$target.sha"
    if [ ! -f "$manifest" ] || [ "$(cat "$manifest")" != "$digest" ]; then
      ci_hit=0
    fi
  done

  if [ "${#passthrough[@]}" -eq 0 ] && [ "$ci_hit" = "1" ] && ci_cache_ready; then
    log INFO "ci cache hit"
    return
  fi

  bake_args+=(--set "fido.output=type=cacheonly")
  bake_args+=(--set "rocq-repl.output=type=cacheonly")

  log INFO "building ci checks and runtime image cache"
  (
    cd "$repo_root"
    run_with_bake_env docker buildx bake \
      "${bake_args[@]}" \
      "${passthrough[@]}" \
      ci
  )

  for line in "${target_hashes[@]}"; do
    target=${line%% *}
    digest=${line#* }
    printf '%s\n' "$digest" > "$repo_root/.cache/rocq-models/ci/$target.sha"
  done
}

check_committed_model_mirrors() {
  log INFO "checking committed model mirrors"
  make_rocq_models
  git -C "$repo_root" diff --exit-code -- src/fido/rocq/
}

check_generated_workflow_files() {
  log INFO "checking generated workflow files"
  (
    cd "$repo_root"
    "$repo_root/fido" gen-workflows
  )
  git -C "$repo_root" diff --exit-code -- .github/workflows/ci.yml tools/build_graph.sh
}

add_mount_if_exists() {
  local path=$1
  if [ -e "$path" ]; then
    run_args+=(--volume "$path:$path")
  fi
}

run_container() {
  mkdir -p "$HOME/workspace" "$HOME/.cache/copilot"
  secret_args=()
  if [ -f "$secret" ]; then
    chmod 600 "$secret"
    secret_args=(--volume "$secret:/run/secrets/fido-secret:ro")
  elif [ "$need_secret" = "1" ]; then
    echo "secret file not found: $secret" >&2
    return 2
  fi

  run_args=(
    --rm
    --interactive
    --user "$(id -u):$(id -g)"
    --env "HOME=$HOME"
    --env "PYTHONPATH=/workspace/src"
    --network host
    --volume "$repo_root:/workspace"
    --volume "$HOME/workspace:$HOME/workspace"
    "${secret_args[@]}"
    --workdir /workspace
  )
  if [ "$named_run" = "1" ]; then
    run_args=(--name "$container" "${run_args[@]}")
  fi
  if [ -n "$container_entrypoint" ]; then
    run_args+=(--entrypoint "$container_entrypoint")
  fi
  add_mount_if_exists "$HOME/.claude"
  add_mount_if_exists "$HOME/.claude.json"
  add_mount_if_exists "$HOME/.config/gh"
  add_mount_if_exists "$HOME/.cache/copilot"

  log INFO "starting container image=$run_image"
  docker run "${run_args[@]}" "$run_image" "$@"
}

run_fido_image() {
  build_image fido "$image"
  run_container "$@"
}

run_fido_test_image() {
  build_image fido-test "$test_image"
  run_container "$@"
}

run_fido_test_python_image() {
  build_image fido-test "$test_image"
  container_entrypoint=/opt/fido-venv/bin/python3 run_container "$@"
}

run_fido_pyproject_image() {
  build_image fido-test "$test_image"
  container_entrypoint=/workspace/pyproject run_container "$@"
}

run_fido_module_image() {
  run_fido_test_python_image -m "$@"
}

require_host_chat_tools() {
  if ! command -v claude >/dev/null 2>&1; then
    echo "fido chat requires claude on PATH" >&2
    return 127
  fi
}

run_host_chat() {
  local persona_file=$repo_root/sub/persona.md
  local persona_text
  local chat_args=()
  require_host_chat_tools || return
  if [ ! -f "$persona_file" ]; then
    echo "fido chat persona file not found: $persona_file" >&2
    return 1
  fi
  persona_text=$(<"$persona_file")
  if [ "$#" -eq 0 ]; then
    chat_args=(/remote-control)
  else
    chat_args=("$@")
  fi
  cd "$repo_root"
  export CLAUDE_CODE_NO_FLICKER=1
  exec nice -n19 claude \
    --permission-mode=bypassPermissions \
    --continue \
    --append-system-prompt "$persona_text" \
    "${chat_args[@]}"
}

run_rocq_repl_image() {
  make_rocq_models
  build_image rocq-repl "$rocq_repl_image"
  run_container "$@"
}

run_rocq_lsp_image() {
  make_rocq_models
  run_fido_test_python_image "$@"
}

prune_restart_buildkit_async() {
  if [ "$prune_on_restart" != "1" ]; then
    return
  fi
  (
    if docker buildx prune \
      --builder "$builder" \
      --force \
      --keep-storage "$prune_keep_storage" \
      >/dev/null 2>&1; then
      log INFO "pruned buildkit cache action=done keep_storage=$prune_keep_storage"
    else
      log WARN "buildkit prune failed action=ignored keep_storage=$prune_keep_storage"
    fi
  ) &
  log INFO "pruning buildkit cache action=async pid=$! keep_storage=$prune_keep_storage"
}

prune_buildkit() {
  ensure_buildx_builder
  log INFO "pruning buildkit cache action=manual keep_storage=$prune_keep_storage"
  docker buildx prune \
    --builder "$builder" \
    --force \
    --keep-storage "$prune_keep_storage"
}

ansi_enabled() {
  [ -z "${NO_COLOR:-}" ] && { [ -n "${FORCE_COLOR:-}" ] || [ -t 1 ]; }
}

ansi_wrap() {
  local code=$1
  shift
  if ansi_enabled; then
    printf '\033[%sm%s\033[0m' "$code" "$*"
  else
    printf '%s' "$*"
  fi
}

ansi_bold() {
  ansi_wrap "1" "$@"
}

ansi_dim() {
  ansi_wrap "2" "$@"
}

ansi_green() {
  ansi_wrap "32" "$@"
}

ansi_red_bold() {
  ansi_wrap "1;31" "$@"
}

format_host_resources() {
  local load_1 load_5 load_15
  local mem_total_kib mem_available_kib mem_used_kib
  local disk_total_kib disk_used_kib
  local key value _
  local resource_fields
  read -r load_1 load_5 load_15 _ < /proc/loadavg
  while read -r key value _; do
    case "$key" in
      MemTotal:)
        mem_total_kib=$value
        ;;
      MemAvailable:)
        mem_available_kib=$value
        ;;
    esac
  done < /proc/meminfo
  mem_used_kib=$((mem_total_kib - mem_available_kib))
  read -r disk_total_kib disk_used_kib < <(df -Pk / | awk 'NR==2 {print $2, $3}')
  resource_fields=$(awk \
    -v mem_used_kib="$mem_used_kib" \
    -v mem_total_kib="$mem_total_kib" \
    -v disk_used_kib="$disk_used_kib" \
    -v disk_total_kib="$disk_total_kib" \
    'BEGIN {
      printf "%.1fGiB %.1fGiB %d %.1fGiB %.1fGiB %d",
        mem_used_kib/1024/1024,
        mem_total_kib/1024/1024,
        (mem_used_kib*100)/mem_total_kib,
        disk_used_kib/1024/1024,
        disk_total_kib/1024/1024,
        (disk_used_kib*100)/disk_total_kib
    }')
  printf '%s cpu load %s/%s %s, mem %s/%s (%s%%), disk / %s/%s (%s%%)\n' \
    "$(ansi_bold 'host:')" \
    "$load_1" "$(nproc)" \
    "$(ansi_dim "($load_5, $load_15)")" \
    $resource_fields
}

fetch_status_payload() {
  local payload=$1
  local port=${FIDO_PORT:-9000}
  local status_url=${FIDO_STATUS_URL:-http://127.0.0.1:${port}/status.json}
  local curl_args=(
    -fsS
    --connect-timeout 1
    --max-time 1
    -H 'Accept: application/json'
  )
  curl "${curl_args[@]}" "$status_url" >"$payload" 2>/dev/null
}

require_status_tools() {
  if ! command -v jq >/dev/null 2>&1; then
    echo "fido status requires jq on PATH" >&2
    return 127
  fi
  if ! command -v curl >/dev/null 2>&1; then
    echo "fido status requires curl on PATH" >&2
    return 127
  fi
}

status_fast_path() {
  local payload
  local color_json=false
  local esc_reset= esc_bold= esc_dim= esc_green= esc_red_bold=
  local esc_cyan= esc_magenta= esc_yellow_bg= esc_green_bg= esc_dark_gray=
  local jq_program
  require_status_tools || return
  payload=$(mktemp)
  if ansi_enabled; then
    color_json=true
    esc_reset=$'\033[0m'
    esc_bold=$'\033[1m'
    esc_dim=$'\033[2m'
    esc_green=$'\033[32m'
    esc_red_bold=$'\033[1;31m'
    esc_cyan=$'\033[36m'
    esc_magenta=$'\033[35m'
    esc_yellow_bg=$'\033[43m'
    esc_green_bg=$'\033[42m'
    esc_dark_gray=$'\033[90m'
  fi
  if fetch_status_payload "$payload"; then
    jq -r \
      --argjson color "$color_json" \
      --arg reset "$esc_reset" \
      --arg bold "$esc_bold" \
      --arg dim "$esc_dim" \
      --arg green "$esc_green" \
      --arg red_bold "$esc_red_bold" \
      --arg cyan "$esc_cyan" \
      --arg magenta "$esc_magenta" \
      --arg yellow_bg "$esc_yellow_bg" \
      --arg green_bg "$esc_green_bg" \
      --arg dark_gray "$esc_dark_gray" \
      '
      def style($code; $text): if $color then ($code + $text + $reset) else $text end;
      def bold($text): style($bold; $text);
      def dim($text): style($dim; $text);
      def green($text): style($green; $text);
      def red_bold($text): style($red_bold; $text);
      def cyan($text): style($cyan; $text);
      def magenta($text): style($magenta; $text);
      def yellow_bg($text): style($yellow_bg; $text);
      def green_bg($text): style($green_bg; $text);
      def dark_gray($text): style($dark_gray; $text);
      def uptime($seconds):
        if $seconds == null then null
        else ($seconds | floor) as $s
        | if $s < 60 then "\($s)s"
          elif $s < 3600 then "\(($s / 60)|floor)m"
          else ((($s / 3600)|floor)|tostring) + "h"
               + (if ((($s / 60)|floor) % 60) > 0
                  then ((((($s / 60)|floor) % 60))|tostring) + "m"
                  else ""
                  end)
          end
        end;
      def reset_at($raw):
        if ($raw | type) != "string" then null
        else ($raw | gsub("T"; " ") | sub("\\+00:00$"; " UTC"))
        end;
      def provider_status_style($ps; $text):
        if $ps == null then $text
        elif $ps.paused then dark_gray($text)
        elif (($ps.warning // false) or ($ps.level == "unavailable")) then dim($text)
        else $text
        end;
      def provider_summary($ps):
        if $ps.unavailable_reason != null then "\($ps.provider) unavailable"
        elif $ps.percent_used == null then "\($ps.provider) limits unknown"
        else "\($ps.provider) \($ps.percent_used)%"
             + ([(if $ps.window_name then ($ps.window_name | gsub("_"; " ")) else empty end),
                 (if $ps.resets_at then "resets " + reset_at($ps.resets_at) else empty end)]
                | map(select(. != null and . != ""))
                | if length > 0 then " (" + join(", ") + ")" else "" end)
        end;
      def rate_window($w; $name):
        if $w == null then empty
        else "\($name) \($w.used)/\($w.limit)"
             + (if $w.resets_at then " (" + reset_at($w.resets_at) + ")" else "" end)
        end;
      def worker_is_agent_talker($repo):
        if $repo.claude_talker != null then ($repo.claude_talker.kind == "worker")
        else (($repo.session_owner // "") | startswith("worker-"))
        end;
      def agent_pid($repo):
        if $repo.claude_talker != null and $repo.claude_talker.claude_pid != null then $repo.claude_talker.claude_pid
        else ($repo.session_pid // null)
        end;
      def cache_line($repo):
        if $repo.issue_cache == null or ($repo.issue_cache.loaded // false | not) then empty
        else "  " + bold("Cache:") + "  "
             + ([dim("\($repo.issue_cache.open_issues) open"),
                 dim("applied \($repo.issue_cache.events_applied)")]
                + (if ($repo.issue_cache.events_dropped_stale // 0) > 0 then [dim("stale-dropped \($repo.issue_cache.events_dropped_stale)")] else [] end)
                + (if $repo.issue_cache.last_reconcile_at != null then [dim("reconciled drift \($repo.issue_cache.last_reconcile_drift)")] else [] end)
                | join(", "))
        end;
      def agent_line($repo):
        if agent_pid($repo) == null and ($repo.session_alive // false | not) then empty
        else "  " + bold("\($repo.provider):") + " "
             + dim(if agent_pid($repo) != null then "pid \(agent_pid($repo))" else "agent" end)
             + ([(if ($repo.session_alive // false) and (worker_is_agent_talker($repo) | not) and ($repo.claude_talker == null) then dim("session idle") else empty end),
                 (if ($repo.session_dropped_count // 0) > 0
                  then red_bold("dropped " + (if $repo.session_dropped_count == 1 then "session " else "sessions " end) + ($repo.session_dropped_count|tostring))
                  else empty
                  end)]
                | map(select(. != null and . != ""))
                | if length > 0 then " " + dim("(") + join(", ") + dim(")") else "" end)
        end;
      def worker_state($repo):
        if $repo.provider_status != null and ($repo.provider_status.paused // false) then
          dark_gray("paused for \($repo.provider_status.provider) reset"
            + (if $repo.provider_status.resets_at then " until " + reset_at($repo.provider_status.resets_at) else "" end))
        elif $repo.task_number != null and $repo.task_total != null then
          bold("task \($repo.task_number)/\($repo.task_total)\(if ($repo.rescoping // false) then "?" else "" end)")
          + (if $repo.current_task != null then " — " + $repo.current_task else "" end)
        elif $repo.current_task != null then
          "task: " + $repo.current_task
        elif (($repo.what // "") | gsub("^\\s+|\\s+$"; "") | length) > 0 then
          ($repo.what | gsub("^\\s+|\\s+$"; ""))
        else
          "waiting for work"
        end;
      def worker_line($repo):
        (if $repo.current_task != null or worker_is_agent_talker($repo)
         then (if $color then "" else "* " end) + green_bg("Worker:")
         else "  " + bold("Worker:")
         end)
        + " " + worker_state($repo);
      def webhook_lines($repo):
        ($repo.webhook_activities // [])
        | sort_by(if $repo.claude_talker != null and $repo.claude_talker.kind == "webhook" and .thread_id == $repo.claude_talker.thread_id then 0 else 1 end)
        | . as $all
        | ($all[:5]) as $shown
        | (($all | length) - ($shown | length)) as $overflow
        | [range(0; $shown|length) as $i
            | $shown[$i] as $w
            | "  "
              + dim(if $overflow == 0 and $i == (($shown|length) - 1) then "└─" else "├─" end)
              + " "
              + (if $repo.claude_talker != null and $repo.claude_talker.kind == "webhook" and $w.thread_id == $repo.claude_talker.thread_id
                 then yellow_bg("webhook:")
                 else bold("webhook:")
                 end)
              + " " + $w.description
              + " " + dim("(" + uptime($w.elapsed_seconds) + ")")
          ]
          + (if $overflow > 0 then [dim("  └─ +\($overflow) more webhook" + (if $overflow == 1 then "" else "s" end))] else [] end);
      def repo_header($repo):
        bold("\($repo.repo_name):")
        + " "
        + (if $repo.fido_running then green("fido running") else dim("fido waiting") end)
        + " — "
        + ([provider_status_style($repo.provider_status; ($repo.provider // "unknown")),
            (if ($repo.crash_count // 0) > 0 then red_bold("crashes \($repo.crash_count)") else empty end),
            (if $repo.worker_uptime_seconds != null then dim("up " + uptime($repo.worker_uptime_seconds)) else empty end),
            (if ($repo.is_stuck // false) then red_bold("BUSY") else empty end),
            (if ($repo.crash_count // 0) > 0 and $repo.last_crash_error != null then red_bold("last crash: " + $repo.last_crash_error) else empty end)]
           | map(select(. != null and . != ""))
           | join(", "));
      def issue_line($repo):
        "  " + bold("Issue:") + " " + cyan("#\($repo.issue)")
        + (if $repo.issue_title != null then " " + dim("—") + " " + $repo.issue_title else "" end)
        + (if $repo.issue_elapsed_seconds != null then " " + dim("(elapsed " + uptime($repo.issue_elapsed_seconds) + ")") else "" end);
      def pr_line($repo):
        if $repo.pr_number == null then empty
        else "  " + bold("PR:") + "     " + magenta("#\($repo.pr_number)")
             + (if $repo.pr_title != null then " " + dim("—") + " " + $repo.pr_title else "" end)
        end;
      [
        bold("fido:") + " " + green("UP")
        + (if .fido_uptime_seconds != null then " " + dim("(uptime " + uptime(.fido_uptime_seconds) + ")") else "" end),
        (if .activities | map(.provider_status) | map(select(. != null)) | unique_by(.provider) | length > 0
         then bold("limits:") + " "
              + (.activities | map(.provider_status) | map(select(. != null)) | unique_by(.provider) | map(provider_status_style(.; provider_summary(.))) | join(" | "))
         else empty
         end),
        (if .rate_limit != null
         then bold("GitHub:") + " " + rate_window(.rate_limit.rest; "REST") + ", " + rate_window(.rate_limit.graphql; "GraphQL")
         else empty
         end)
      ]
      + (.activities // [] | map(
          [repo_header(.),
           agent_line(.),
           cache_line(.),
           (if .issue == null then "  no assigned issues" else issue_line(.) end),
           pr_line(.),
           (if .issue == null then empty else worker_line(.) end)]
          + (if .issue == null then [] else webhook_lines(.) end)
        ) | flatten)
      | map(select(. != null and . != ""))
      | .[]
      ' "$payload"
  else
    printf '%s %s\n' "$(ansi_bold 'fido:')" "$(ansi_red_bold 'DOWN')"
  fi
  rm -f "$payload"
  format_host_resources
}

supervise_up() {
  while true; do
    sync_runner
    build_image fido "$image"
    set +e
    run_container "$@"
    status=$?
    set -e
    if [[ "$restart_codes" == *" $status "* ]]; then
      log INFO "container exited code=$status action=restart"
      prune_restart_buildkit_async
      continue
    fi
    if [[ "$stop_codes" == *" $status "* ]]; then
      log INFO "container exited code=$status action=stop"
      exit 0
    fi
    log ERROR "container exited code=$status action=fail"
    exit "$status"
  done
}

case "$command" in
  help)
    run_fido_module_image fido.fido_help "${@:2}"
    ;;
  up)
    shift
    need_secret=1
    named_run=1
    redirect_up_logs
    supervise_up python3 -m fido.main --secret-file /run/secrets/fido-secret "$@"
    ;;
  down)
    docker stop "$container" 2>/dev/null || true
    exit 0
    ;;
  ci)
    ci_images "${@:2}"
    check_committed_model_mirrors
    check_generated_workflow_files
    ;;
  gen-workflows)
    ensure_buildx_builder
    mkdir -p "$repo_root/.cache"
    (
      cd "$repo_root"
      run_with_bake_env docker buildx bake --print ci fido-test make-rocq > .cache/bake-plan.json
    )
    python3 "$repo_root/tools/gen_workflows.py" --plan .cache/bake-plan.json
    ;;
  prune)
    prune_buildkit
    ;;
  make-rocq)
    shift
    if [ "${1:-}" = "--smart-output" ]; then
      make_rocq_smart_output "$@"
    else
      make_rocq_models "$@"
    fi
    ;;
  status)
    status_fast_path
    ;;
  task)
    run_fido_module_image fido.cli "${@:2}"
    ;;
  gh-status)
    run_fido_module_image fido.gh_status "${@:2}"
    ;;
  chat)
    shift
    run_host_chat "$@"
    ;;
  sync-tasks)
    run_fido_module_image fido.sync_tasks_cli "${@:2}"
    ;;
  tests)
    run_fido_pyproject_image python3 -m fido.tests_main "${@:2}"
    ;;
  traceback)
    run_fido_test_python_image -m fido.rocq_traceback "${@:2}"
    ;;
  repl)
    run_rocq_repl_image python3 -m fido.rocq_repl "${@:2}"
    ;;
  rocq-lsp)
    run_rocq_lsp_image -m fido.rocq_lsp --stdio "${@:2}"
    ;;
  lsp)
    run_rocq_lsp_image -m fido.rocq_lsp "${@:2}"
    ;;
  ruff)
    run_fido_pyproject_image ruff "${@:2}"
    ;;
  pyright)
    run_fido_pyproject_image pyright "${@:2}"
    ;;
  pytest)
    run_fido_pyproject_image pytest "${@:2}"
    ;;
  *)
    echo "unsupported fido command: $command" >&2
    echo "run ./fido help for supported commands" >&2
    exit 2
    ;;
esac
